// Prisma schema — your database models.
// After editing, run:  yarn prisma:migrate   (creates/updates tables and regenerates the client)
// Prisma 7 note: the connection URL lives in `prisma.config.ts`, not here.
// Docs: https://www.prisma.io/docs

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// Starter models for Celebrity Name Chain. Extend these to enforce the
// rules in the project spec (see the tiered goals for unique constraints, etc.).
model Game {
  id        Int      @id @default(autoincrement())
  roomCode  String
  createdAt DateTime @default(now())
  answers   Answer[]
}

model Answer {
  id        Int      @id @default(autoincrement())
  firstName String
  lastName  String
  username  String
  createdAt DateTime @default(now())
  game      Game     @relation(fields: [gameId], references: [id])
  gameId    Int
}
